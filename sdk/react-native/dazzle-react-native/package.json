{
  "name": "dazzle-react-native",
  "version": "1.0.0-beta.4",
  "description": "Dazzle SDK for React Native — embedded in-process database with HNSW vector search and a ChatAgent runtime for on-device LLM agents. Includes five swappable LLMClient adapters (LlamaCpp, LiteRT-LM, FoundationModels, OpenAI-compatible, Anthropic). Same libdazzle.so / Dazzle.xcframework the native Android / iOS SDKs ship — zero behaviour drift across platforms.",
  "main": "src/index.ts",
  "source": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src",
    "lib",
    "android/build.gradle",
    "android/src",
    "android/AndroidManifest.xml",
    "ios",
    "cpp",
    "dazzle-react-native.podspec",
    "react-native.config.js",
    "tsconfig.json",
    "README.md",
    "LICENSE",
    "!**/*.tsbuildinfo",
    "!android/build/",
    "!android/.gradle/",
    "!ios/build/",
    "!ios/Pods/",
    "!**/.DS_Store"
  ],
  "scripts": {
    "build": "tsc -p .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "dazzle",
    "valkey",
    "redis",
    "vector-search",
    "hnsw",
    "embedding",
    "llm",
    "agent",
    "chat-agent",
    "on-device",
    "edge-ai",
    "embedded-database",
    "anthropic",
    "claude",
    "openai",
    "llama-cpp",
    "litert-lm",
    "foundation-models"
  ],
  "homepage": "https://github.com/IvanAliaga/dazzle-sdk",
  "bugs": {
    "url": "https://github.com/IvanAliaga/dazzle-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IvanAliaga/dazzle-sdk.git",
    "directory": "sdk/react-native/dazzle-react-native"
  },
  "author": {
    "name": "Ivan Aliaga",
    "email": "ivanaliaga22@gmail.com",
    "url": "https://github.com/IvanAliaga"
  },
  "license": "Apache-2.0",
