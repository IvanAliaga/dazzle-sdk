diff --git a/src/android_compat.h b/src/android_compat.h
new file mode 100644
index 0000000..0c01a63
--- /dev/null
+++ b/src/android_compat.h
@@ -0,0 +1,50 @@
+#ifndef ANDROID_COMPAT_H
+#define ANDROID_COMPAT_H
+#ifdef __ANDROID__
+#include <dirent.h>
+#include <fnmatch.h>
+#include <string.h>
+#pragma GCC diagnostic push
+#pragma GCC diagnostic ignored "-Wdeprecated-declarations"
+#include <stdlib.h>
+typedef struct { size_t gl_pathc; char **gl_pathv; } glob_t;
+static inline void globfree(glob_t *g) {
+    if (!g) return;
+    for (size_t i = 0; i < g->gl_pathc; i++) free(g->gl_pathv[i]);
+    free(g->gl_pathv); g->gl_pathv = NULL; g->gl_pathc = 0;
+}
+static inline int glob(const char *pattern, int flags, void *errfunc, glob_t *g) {
+    (void)flags; (void)errfunc;
+    g->gl_pathc = 0; g->gl_pathv = NULL;
+    char dir[1024], pat[256];
+    const char *slash = strrchr(pattern, '/');
+    if (slash) {
+        size_t dlen = (size_t)(slash - pattern);
+        if (dlen >= sizeof(dir)) dlen = sizeof(dir) - 1;
+        memcpy(dir, pattern, dlen); dir[dlen] = '\0';
+        snprintf(pat, sizeof(pat), "%s", slash + 1);
+    } else { memcpy(dir, ".", 2); snprintf(pat, sizeof(pat), "%s", pattern); }
+    DIR *d = opendir(dir);
+    if (!d) return -1;
+    size_t cap = 8;
+    g->gl_pathv = (char **)malloc(cap * sizeof(char *));
+    if (!g->gl_pathv) { closedir(d); return -1; }
+    struct dirent *ent;
+    while ((ent = readdir(d)) != NULL) {
+        if (fnmatch(pat, ent->d_name, 0) == 0) {
+            if (g->gl_pathc >= cap) {
+                cap *= 2; char **tmp = (char **)realloc(g->gl_pathv, cap * sizeof(char *));
+                if (!tmp) break; g->gl_pathv = tmp;
+            }
+            char fullpath[1280];
+            snprintf(fullpath, sizeof(fullpath), "%s/%s", dir, ent->d_name);
+            g->gl_pathv[g->gl_pathc] = strdup(fullpath);
+            if (g->gl_pathv[g->gl_pathc]) g->gl_pathc++;
+        }
+    }
+    closedir(d);
+    #pragma GCC diagnostic pop
+    return g->gl_pathc > 0 ? 0 : -1;
+}
+#endif
+#endif
