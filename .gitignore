local.properties

# SPM build artifacts (Package.swift in sdk/ios/)
sdk/ios/.build/
sdk/ios/.swiftpm/

# On-device model weights and runtime caches — downloaded/generated,
# never committed (multi-GB artifacts).
*.litertlm
*.xnnpack_cache
*.gguf
artifacts/

# NQ slice raw download (materialised by research/scripts/nq_slice.py) —
# the derived JSONL slice under experiment/backends/android/assets/nq_slice/
# is committed; the 44 MB parquet source is not.
research/data/nq_slice/raw/

# HNSW parity dataset (regenerated deterministically from seed=42 via
# research/scripts/hnsw_parity.py — 164 MB of float32 vectors, not worth
# committing). The summary JSONs under research/results/ are committed.
research/data/hnsw_parity/

# Editor / agent-local state.
.claude/

# sqlite-vector-ai xcframework (Elastic License 2.0, bench-only, NOT
# redistributed — run sqlitevectorai/download_xcframework.sh to fetch).
experiment/backends/ios/sqlitevectorai/vector.xcframework/
# Sample test intermediate dirs (results JSONs ARE tracked for reproducibility)
samples/_scripts/_test_logs/

# Flutter / Dart — SDK package
# Native artefacts vendored by samples/_scripts/link_flutter.sh (not
# tracked — rebuild with the same script whenever the native SDK changes).
sdk/flutter/dazzle_flutter/android/libs/*.aar
sdk/flutter/dazzle_flutter/ios/Classes/vendored/

